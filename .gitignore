# Build directories
/build/
/cmake-build-*/

# CMake generated files (in-source build protection)
/CMakeFiles/
/CMakeCache.txt
/cmake_install.cmake
/CTestTestfile.cmake
/Makefile
/install_manifest.txt
/compile_commands.json

# Build artifacts
/*.o
/*.obj
/*.a
/*.lib
/*.so
/*.dylib
/*.dll
/*.exe

# Recording output
*.raw

# Hot pixel calibration data (machine-specific)
config/hot_pixels.json
